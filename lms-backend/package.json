{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "LMS Backend - Express + TypeScript boilerplate",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --files\" src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "dotenv -o -e .env -- prisma generate",
    "db:push": "dotenv -o -e .env -- prisma db push",
    "db:seed": "dotenv -o -e .env -- ts-node prisma/seed.ts",
    "db:studio": "dotenv -o -e .env -- prisma studio"
  },
  "prisma": {
    "seed": "dotenv -o -e .env -- ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.79.2",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "prisma": "^6.19.3",
    "puppeteer": "^25.2.1",
    "qrcode": "^1.5.4",
    "redis": "^6.0.1",
    "sharp": "^0.35.2",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0"
  }
}
