generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  email              String         @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               Role           @default(STUDENT)
  isActive           Boolean        @default(true)
  mustChangePassword Boolean        @default(false)
  profilePicture     String?
  bio                String?
  lastLogin          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  refreshTokens RefreshToken[] @relation("userRefreshTokens")
  courses       Course[]        @relation("courseCreator")
  enrollments   Enrollment[]
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation("userRefreshTokens", fields: [userId], references: [id])
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Course management (Step 5)
// ---------------------------------------------------------------------------

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ContentType {
  PAGE
  VIDEO
  DOCUMENT
  QUIZ
  ASSIGNMENT
  EXTERNAL_LINK
}

model Course {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  thumbnail   String?
  category    String?
  tags        String[]
  duration    Int?
  difficulty  DifficultyLevel @default(BEGINNER)
  language    String         @default("English")
  status      CourseStatus   @default(DRAFT)
  createdBy   String         @db.ObjectId
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User     @relation("courseCreator", fields: [createdBy], references: [id])
  modules Module[]
  enrollments Enrollment[]
  autoEnrollmentRules AutoEnrollmentRule[]
}

model Module {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String   @db.ObjectId
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents Content[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Content {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String      @db.ObjectId
  type        ContentType
  title       String
  description String?
  contentJson Json?
  videoUrl    String?
  fileUrl     String?
  externalUrl String?
  duration    Int?
  order       Int
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  progress Progress[]
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Enrollment & Progress Tracking (Step 6)
// ---------------------------------------------------------------------------

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PENDING
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Enrollment {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  userId             String           @db.ObjectId
  courseId           String           @db.ObjectId
  status             EnrollmentStatus @default(ACTIVE)
  progressPercentage Float            @default(0)
  enrolledAt         DateTime         @default(now())
  completedAt        DateTime?
  droppedAt          DateTime?
  lastAccessedAt     DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  course   Course     @relation(fields: [courseId], references: [id])
  progress Progress[]

  @@unique([userId, courseId])
}

model Progress {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId    String         @db.ObjectId
  contentId       String         @db.ObjectId
  status          ProgressStatus @default(NOT_STARTED)
  progressPercent Float          @default(0)
  timeSpent       Int            @default(0)
  lastAccessedAt  DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  content    Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, contentId])
}

model AutoEnrollmentRule {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  ruleType   String
  ruleConfig Json
  courseId   String   @db.ObjectId
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}
