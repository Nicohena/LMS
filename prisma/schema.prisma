generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  email              String         @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               Role           @default(STUDENT)
  isActive           Boolean        @default(true)
  mustChangePassword Boolean        @default(false)
  profilePicture     String?
  bio                String?
  lastLogin          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  refreshTokens RefreshToken[] @relation("userRefreshTokens")
  courses       Course[]        @relation("courseCreator")
  enrollments   Enrollment[]
  quizzes       Quiz[]          @relation("quizCreator")
  quizAttempts  QuizAttempt[]
  manualGrading ManualGrading[]
  assignments          Assignment[]      @relation("assignmentCreator")
  submissions          Submission[]      @relation("submissionUser")
  gradedSubmissions    Submission[]      @relation("submissionGrader")
  peerReviewsGiven     PeerReview[]      @relation("peerReviewReviewer")
  gradeChanges         GradeHistory[]    @relation("gradeChanger")
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation("userRefreshTokens", fields: [userId], references: [id])
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Course management (Step 5)
// ---------------------------------------------------------------------------

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ContentType {
  PAGE
  VIDEO
  DOCUMENT
  QUIZ
  ASSIGNMENT
  EXTERNAL_LINK
}

model Course {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  thumbnail   String?
  category    String?
  tags        String[]
  duration    Int?
  difficulty  DifficultyLevel @default(BEGINNER)
  language    String         @default("English")
  status      CourseStatus   @default(DRAFT)
  createdBy   String         @db.ObjectId
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User     @relation("courseCreator", fields: [createdBy], references: [id])
  modules Module[]
  enrollments Enrollment[]
  autoEnrollmentRules AutoEnrollmentRule[]
}

model Module {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String   @db.ObjectId
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents Content[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Content {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String      @db.ObjectId
  type        ContentType
  title       String
  description String?
  contentJson Json?
  videoUrl    String?
  fileUrl     String?
  externalUrl String?
  duration    Int?
  order       Int
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Quiz / Assignment relations will be added in a future step
  // (the ContentType enum reserves QUIZ and ASSIGNMENT for forward compat).

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  progress Progress[]
  quiz     Quiz?
  assignment Assignment?
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Enrollment & Progress Tracking (Step 6)
// ---------------------------------------------------------------------------

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PENDING
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Enrollment {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  userId             String           @db.ObjectId
  courseId           String           @db.ObjectId
  status             EnrollmentStatus @default(ACTIVE)
  progressPercentage Float            @default(0)
  enrolledAt         DateTime         @default(now())
  completedAt        DateTime?
  droppedAt          DateTime?
  lastAccessedAt     DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  course   Course     @relation(fields: [courseId], references: [id])
  progress Progress[]
  attempts QuizAttempt[]
  submissions Submission[]

  @@unique([userId, courseId])
}

model Progress {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId    String         @db.ObjectId
  contentId       String         @db.ObjectId
  status          ProgressStatus @default(NOT_STARTED)
  progressPercent Float          @default(0)
  timeSpent       Int            @default(0)
  lastAccessedAt  DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  content    Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, contentId])
}

model AutoEnrollmentRule {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  ruleType   String
  ruleConfig Json
  courseId   String   @db.ObjectId
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

// ---------------------------------------------------------------------------
// Quiz & Assessment Engine (Step 7)
// ---------------------------------------------------------------------------

enum QuestionType {
  MULTIPLE_CHOICE_SINGLE
  MULTIPLE_CHOICE_MULTIPLE
  TRUE_FALSE
  FILL_IN_BLANK
  MATCHING
  SORTING
  SHORT_ANSWER
  ESSAY
  FILE_UPLOAD
  HOTSPOT
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  TIMED_OUT
  ABANDONED
}

model Quiz {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  contentId          String?     @unique @db.ObjectId
  title              String
  description        String?
  instructions       String?
  timeLimit          Int?
  passingScore       Float       @default(70)
  maxAttempts        Int         @default(1)
  shuffleQuestions   Boolean     @default(false)
  shuffleAnswers     Boolean     @default(false)
  showFeedback       Boolean     @default(true)
  showCorrectAnswers Boolean     @default(false)
  status             QuizStatus  @default(DRAFT)
  createdBy          String      @db.ObjectId
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  creator   User         @relation("quizCreator", fields: [createdBy], references: [id])
  content   Content?     @relation(fields: [contentId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  quizId        String       @db.ObjectId
  type          QuestionType
  questionText  String
  questionImage String?
  explanation   String?
  options       Json?
  correctAnswer Json?
  points        Int          @default(1)
  order         Int          @default(0)
  isRequired    Boolean      @default(true)
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
  manualGrading ManualGrading[]
}

model QuizAttempt {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  quizId           String        @db.ObjectId
  userId           String        @db.ObjectId
  enrollmentId     String        @db.ObjectId
  attemptNumber    Int           @default(1)
  status           AttemptStatus @default(NOT_STARTED)
  startTime        DateTime?
  endTime          DateTime?
  timeSpent        Int           @default(0)
  score            Float?
  maxPossibleScore Float?
  scorePercentage  Float?
  passed           Boolean?
  answers          Json?
  gradedAt         DateTime?
  gradedBy         String?       @db.ObjectId
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  quiz        Quiz           @relation(fields: [quizId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  enrollment  Enrollment     @relation(fields: [enrollmentId], references: [id])
  answers_rel Answer[]
  grading     ManualGrading[]
}

model ManualGrading {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  attemptId      String   @db.ObjectId
  questionId     String   @db.ObjectId
  pointsAwarded  Float
  pointsPossible Float
  feedback       String?
  gradedBy       String   @db.ObjectId
  gradedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])
  grader   User        @relation(fields: [gradedBy], references: [id])

  @@unique([attemptId, questionId])
}

model Answer {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  attemptId     String   @db.ObjectId
  questionId    String   @db.ObjectId
  answer        Json
  isCorrect     Boolean?
  pointsAwarded Float?
  feedback      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

// ---------------------------------------------------------------------------
// Assignments & Submissions (Step 8)
// ---------------------------------------------------------------------------

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  LATE
  REVISION_REQUESTED
  RESUBMITTED
  GRADED
  RETURNED
}

enum GradingStatus {
  NOT_GRADED
  IN_PROGRESS
  GRADED
}

enum PeerReviewStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Assignment {
  id                     String           @id @default(auto()) @map("_id") @db.ObjectId
  contentId              String?          @unique @db.ObjectId
  title                  String
  description            String?
  instructions           String?
  dueDate                DateTime?
  lateSubmissionDeadline DateTime?
  latePenaltyPercentage  Float            @default(0)
  maxPoints              Float            @default(100)
  allowResubmissions     Boolean          @default(true)
  maxResubmissions       Int              @default(3)
  allowPeerReview        Boolean          @default(false)
  peerReviewDeadline     DateTime?
  peerReviewCount        Int              @default(2)
  requiresFileUpload     Boolean          @default(true)
  allowedFileTypes       String[]
  maxFileSizeMB          Int              @default(10)
  status                 AssignmentStatus @default(DRAFT)
  createdBy              String           @db.ObjectId
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  creator     User         @relation("assignmentCreator", fields: [createdBy], references: [id])
  content     Content?     @relation(fields: [contentId], references: [id])
  rubric      Rubric?
  submissions Submission[]
  peerReviews PeerReview[]
}

model Rubric {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String  @unique @db.ObjectId
  name        String
  description String?
  criteria    Json
  totalPoints Float    @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model Submission {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId      String           @db.ObjectId
  userId            String           @db.ObjectId
  enrollmentId      String           @db.ObjectId
  status            SubmissionStatus @default(NOT_SUBMITTED)
  submittedAt       DateTime?
  version           Int              @default(1)
  content           Json
  feedback          String?
  grade             Float?
  gradedAt          DateTime?
  gradedBy          String?          @db.ObjectId
  gradingStatus     GradingStatus    @default(NOT_GRADED)
  revisionRequested Boolean          @default(false)
  revisionComments  String?
  plagiarismScore   Float?
  plagiarismReport  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  assignment          Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user                User         @relation("submissionUser", fields: [userId], references: [id])
  enrollment          Enrollment   @relation(fields: [enrollmentId], references: [id])
  grader              User?         @relation("submissionGrader", fields: [gradedBy], references: [id])
  peerReviewsReceived PeerReview[]  @relation("peerReviewSubmission")
  gradeHistory        GradeHistory[]
}

model PeerReview {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String           @db.ObjectId
  reviewerId   String           @db.ObjectId
  submissionId String           @db.ObjectId
  status       PeerReviewStatus @default(NOT_STARTED)
  score        Float?
  feedback     String?
  comments     Json?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer   User       @relation("peerReviewReviewer", fields: [reviewerId], references: [id])
  submission Submission @relation("peerReviewSubmission", fields: [submissionId], references: [id], onDelete: Cascade)
}

model GradeHistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  submissionId  String   @db.ObjectId
  previousGrade Float?
  newGrade      Float
  changedBy     String   @db.ObjectId
  reason        String?
  createdAt     DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  changer    User       @relation("gradeChanger", fields: [changedBy], references: [id])
}
