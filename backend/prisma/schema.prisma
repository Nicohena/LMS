// ---------------------------------------------------------------------------

enum EmailTemplateType {
  WELCOME
  PASSWORD_RESET
  ENROLLMENT_CONFIRMATION
  ASSIGNMENT_GRADED
  QUIZ_GRADED
  COURSE_COMPLETED
  ANNOUNCEMENT
  PEER_REVIEW_ASSIGNED
  REVISION_REQUESTED
  CERTIFICATE_ISSUED
  REPORT_READY
}

enum AcademicYearStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model EmailTemplate {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  type         EmailTemplateType @unique
  name         String
  subject      String
  htmlContent  String
  textContent  String?
  placeholders Json
  isActive     Boolean           @default(true)
  version      Int               @default(1)
  updatedBy    String?           @db.ObjectId
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  updater User? @relation(fields: [updatedBy], references: [id])
}

model GradingScale {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  type        String
  grades      Json
  isDefault   Boolean  @default(false)
  createdBy   String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id])
}

model AcademicYear {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(ACTIVE)
  isCurrent Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  courses Course[]
  sections       Section[]
  studentSections StudentSection[]
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  courseId  String   @db.ObjectId
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model TeacherPermission {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  autoPublish     Boolean  @default(true)
  maxCourseSlots  Int      @default(10)
  canEnrollStudents Boolean @default(true)
  qualityScore    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InviteCode {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  role        Role      @default(STUDENT)
  createdBy   String    @db.ObjectId
  usedBy      String?   @db.ObjectId @unique
  isUsed      Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator User  @relation("inviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  usedByUser User? @relation("inviteUsedBy", fields: [usedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model GradeDispute {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  attemptId     String   @db.ObjectId
  userId        String   @db.ObjectId
  reason        String
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedBy    String?  @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

model Escalation {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  submissionId String?          @db.ObjectId
  attemptId    String?          @db.ObjectId
  userId       String           @db.ObjectId
  teacherId    String?          @db.ObjectId
  adminId      String?          @db.ObjectId
  reason       String
  status       EscalationStatus @default(OPEN)
  teacherNotes String?
  adminNotes   String?
  resolution   String?
  resolvedBy   String?          @db.ObjectId
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user       User         @relation("escalationUser", fields: [userId], references: [id], onDelete: Cascade)
  teacher    User?        @relation("escalationTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  admin      User?        @relation("escalationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  submission Submission?  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

enum EscalationStatus {
  OPEN
  TEACHER_REVIEW
  FORWARDED_TO_ADMIN
  RESOLVED
  ESCALATED
}

enum AdminPermission {
  USERS_VIEW
  USERS_CREATE
  USERS_DELETE
  USERS_ROLE_CHANGE
  CONTENT_MODERATE
  COURSE_QUALITY_MANAGE
  ANALYTICS_VIEW
  ANALYTICS_EXPORT
  SUPPORT_IMPERSONATE
  SYSTEM_CONFIG
  SYSTEM_MAINTENANCE
  ADMIN_ROLES_MANAGE
  ALL_ACCESS
}

model AdminRole {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  name        String          @unique
  description String?
  permissions AdminPermission[]
  isDefault   Boolean         @default(false)
  isSystem    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  admins Admin[]
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  roleId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AdminRole @relation(fields: [roleId], references: [id])
}

// ===========================================================================
// SCHOOL-BASED LMS — Academic Structure Models (Ethiopian Education System)
// ===========================================================================

model Grade {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique // e.g. "Grade 9", "Grade 10"
  level     Int      @unique // numeric level for ordering (9, 10, 11, 12)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections  Section[]
}

model Section {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String   // e.g. "9A", "9B"
  gradeId        String   @db.ObjectId
  academicYearId String   @db.ObjectId
  capacity       Int      @default(40)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  grade        Grade        @relation(fields: [gradeId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  sectionSubjects SectionSubject[]
  studentSections StudentSection[]
  timetables    Timetable[]

  @@unique([name, academicYearId])
}

model Subject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique // e.g. "Mathematics", "English", "Biology"
  code        String?  @unique // e.g. "MATH", "ENG"
  description String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sectionSubjects SectionSubject[]
}

model SectionSubject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sectionId   String   @db.ObjectId
  subjectId   String   @db.ObjectId
  teacherId   String?  @db.ObjectId // teacher assigned to teach this subject in this section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section       Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id])
  teacher       User?         @relation("sectionSubjectTeacher", fields: [teacherId], references: [id])
  sectionContents   SectionContent[]
  sectionQuizzes    SectionQuiz[]
  sectionAssignments SectionAssignment[]
  timetables        Timetable[]

  @@unique([sectionId, subjectId])
}

model StudentSection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  sectionId   String   @db.ObjectId
  academicYearId String @db.ObjectId
  enrolledAt  DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE | TRANSFERRED | GRADUATED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student       User          @relation("studentSectionUser", fields: [studentId], references: [id])
  section       Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear  @relation(fields: [academicYearId], references: [id])
  sectionProgress SectionProgress[]

  @@unique([studentId, sectionId, academicYearId])
}

// --- Content linked to Section-Subject (replaces courseId on Content) ---
model SectionContent {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  sectionSubjectId String        @db.ObjectId
  type             ContentType
  title            String
  description      String?
  contentJson      Json?
  videoUrl         String?
  fileUrl          String?
  externalUrl      String?
  duration         Int?
  order            Int           @default(0)
  isPublished      Boolean       @default(true)
  status           ContentStatus @default(PUBLISHED)
  flagReason       String?
  qualityScore     Float?
  moderatedAt      DateTime?
  moderatedBy      String?       @db.ObjectId
  createdBy        String        @db.ObjectId
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sectionSubject SectionSubject @relation(fields: [sectionSubjectId], references: [id], onDelete: Cascade)
  creator        User           @relation("sectionContentCreator", fields: [createdBy], references: [id])
  sectionProgress SectionProgress[]
  sectionQuizzes       SectionQuiz[]
  sectionAssignments SectionAssignment[]
}

// --- Quiz linked to Section-Subject ---
model SectionQuiz {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  sectionContentId   String?     @db.ObjectId
  sectionSubjectId   String      @db.ObjectId
  title              String
  description        String?
  instructions       String?
  timeLimit          Int?
  passingScore       Float       @default(70)
  maxAttempts        Int         @default(1)
  shuffleQuestions   Boolean     @default(false)
  shuffleAnswers     Boolean     @default(false)
  showFeedback       Boolean     @default(true)
  showCorrectAnswers Boolean     @default(false)
  status             QuizStatus  @default(DRAFT)
  createdBy          String      @db.ObjectId
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  sectionSubject SectionSubject @relation(fields: [sectionSubjectId], references: [id], onDelete: Cascade)
  sectionContent SectionContent? @relation(fields: [sectionContentId], references: [id])
  creator        User            @relation("sectionQuizCreator", fields: [createdBy], references: [id])
}

// --- Assignment linked to Section-Subject ---
model SectionAssignment {
  id                     String           @id @default(auto()) @map("_id") @db.ObjectId
  sectionContentId       String?          @db.ObjectId
  sectionSubjectId       String           @db.ObjectId
  title                  String
  description            String?
  instructions           String?
  dueDate                DateTime?
  lateSubmissionDeadline DateTime?
  latePenaltyPercentage  Float            @default(0)
  maxPoints              Float            @default(100)
  allowResubmissions     Boolean          @default(true)
  maxResubmissions       Int              @default(3)
  allowPeerReview        Boolean          @default(false)
  peerReviewDeadline     DateTime?
  peerReviewCount        Int              @default(2)
  requiresFileUpload     Boolean          @default(true)
  allowedFileTypes       String[]
  maxFileSizeMB          Int              @default(10)
  status                 AssignmentStatus @default(DRAFT)
  createdBy              String           @db.ObjectId
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  sectionSubject SectionSubject @relation(fields: [sectionSubjectId], references: [id], onDelete: Cascade)
  sectionContent SectionContent? @relation(fields: [sectionContentId], references: [id])
  creator        User            @relation("sectionAssignmentCreator", fields: [createdBy], references: [id])
}

// --- Progress linked to StudentSection + SectionContent ---
model SectionProgress {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  studentSectionId  String         @db.ObjectId
  sectionContentId  String         @db.ObjectId
  status            ProgressStatus @default(NOT_STARTED)
  progressPercent   Float          @default(0)
  timeSpent         Int            @default(0)
  lastAccessedAt    DateTime       @default(now())
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  studentSection StudentSection @relation(fields: [studentSectionId], references: [id], onDelete: Cascade)
  sectionContent SectionContent @relation(fields: [sectionContentId], references: [id], onDelete: Cascade)

  @@unique([studentSectionId, sectionContentId])
}

// ─── Weekly Class Schedule (Ethiopian Education System) ──────────────────
model Timetable {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  sectionId       String   @db.ObjectId
  sectionSubjectId String? @db.ObjectId
  day             String   // MONDAY | TUESDAY | WEDNESDAY | THURSDAY | FRIDAY | SATURDAY | SUNDAY
  period          Int      // 1st period, 2nd period, etc.
  startTime       String   // e.g. "08:00"
  endTime         String   // e.g. "08:45"
  subjectName     String?  // denormalized for quick display
  teacherName     String?  // denormalized for quick display
  room            String?  // classroom/room number
  breakType       String?  // if this is a break: "SHORT_BREAK" | "LUNCH_BREAK" | null
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  section       Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionSubject SectionSubject? @relation(fields: [sectionSubjectId], references: [id])
}
